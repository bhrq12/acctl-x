###############################################################################
# AC Controller UCI Configuration
# /etc/config/acctl
#
# This file is managed by UCI. Do not edit manually unless using UCI.
# Access via LuCI: Administration → Network → AC Controller
#
# IMPORTANT: Set a strong password before starting the service!
#   uci set acctl.@acctl[0].password='your_secure_password_here'
#   uci commit acctl
###############################################################################

config acctl 'acctl'
	option enabled     '1'
	option interface   'br-lan'
	option port        '7960'
	option password    ''

	# Broadcast probe interval in seconds (default: 30)
	option brditv      '30'

	# IP pool reload interval in seconds (default: 300 = 5 minutes)
	option reschkitv   '300'

	# Message processing interval in seconds (default: 3)
	option msgitv      '3'

	# Run as daemon (1=yes, 0=no)
	option daemon      '1'

	# Debug mode (1=yes, 0=no)
	option debug       '0'

	# AP client mode enabled (1=yes, 0=no)
	option ap_enabled   '0'

	# Multi-SSID support (1=yes, 0=no)
	option multi_ssid   '1'

	# Default band for new SSIDs: 2.4GHz, 5GHz, or auto
	option default_band 'auto'

###############################################################################
# IP Address Pool Configuration
# Managed via database: INSERT INTO resource VALUES ('192.168.100.1', '192.168.100.254', '255.255.255.0');
###############################################################################

###############################################################################
# AP Default Configuration Template
# Multiple profiles supported: profile 'office', 'warehouse', 'guest', etc.
# Each profile can contain multiple SSIDs with independent settings
###############################################################################

config profile 'profile_office'
	option name     'Office Network'
	option desc     'Corporate office WiFi configuration'

	# Primary 2.4GHz SSID
	list ssid_2g    'Office-2G'
	option enc_2g   'psk2'
	option key_2g   'changeme123'
	option channel_2g 'auto'
	option mode_2g  'n'
	option power_2g 'auto'

	# Primary 5GHz SSID
	list ssid_5g    'Office-5G'
	option enc_5g   'psk2'
	option key_5g   'changeme123'
	option channel_5g 'auto'
	option mode_5g  'ac'
	option power_5g 'auto'

config profile 'profile_guest'
	option name     'Guest Network'
	option desc     'Guest WiFi with limited access'

	list ssid_2g    'Guest-2G'
	list ssid_5g    'Guest-5G'
	option enc_2g   'psk2'
	option enc_5g   'psk2'
	option key_2g   'guest_wifi_2024'
	option key_5g   'guest_wifi_2024'
	option channel_2g '6'
	option channel_5g '149'
	option mode_2g  'g'
	option mode_5g  'ac'
	option power_2g '80'
	option power_5g '100'

config profile 'profile_iot'
	option name     'IoT Network'
	option desc     'Internet of Things devices'

	list ssid_2g    'IoT-Devices'
	list ssid_5g    'IoT-5G'
	option enc_2g   'wpa2'
	option enc_5g   'wpa2'
	option key_2g   'iot_secure_pass'
	option key_5g   'iot_secure_pass'
	option mode_2g  'n'
	option mode_5g  'ac'
	option isolate  '1'

###############################################################################
# AP Pre-Configuration (MAC-based)
