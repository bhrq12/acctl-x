root = true

[*]
indent_style = tab
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.lua]
indent_style = tab
indent_size = 2

[*.js]
indent_style = tab
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.htm]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 4

[*.mk]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = tab
indent_size = 4
