{
    "luci-app-acctl": {
        "description": "AC Controller - LuCI Web Interface",
        "read": {
            "ubus": {
                "acctl": [ "apiStatus", "apiAps", "apiAlarms", "apiGroups", "apiFirmwares" ]
            }
        },
        "write": {
            "ubus": {
                "acctl": [ "apiApsAction", "apiAlarmsAck", "apiCmd", "apiRestart" ]
            },
            "uci": [ "acctl" ]
        }
    }
}
