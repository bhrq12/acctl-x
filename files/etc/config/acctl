###############################################################################
# Alarm Rules
###############################################################################

config alarm 'ap_offline'
	option name       'AP Offline'
	option level      '2'
	option threshold  '1'
	option window     '60'
	option cooldown   '300'
	option enabled    '1'

config alarm 'signal_weak'
	option name       'Signal Weak'
	option level      '1'
	option threshold  '-75'
	option window     '300'
	option cooldown   '600'
	option enabled    '1'

config alarm 'cpu_overload'
	option name       'CPU Overload'
	option level      '1'
	option threshold  '90'
	option window     '120'
	option cooldown   '900'
	option enabled    '1'

config alarm 'memory_low'
	option name       'Memory Low'
	option level      '1'
	option threshold  '85'
	option window     '300'
	option cooldown   '900'
	option enabled    '1'

config alarm 'user_overload'
	option name       'User Overload'
	option level      '1'
	option threshold  '50'
	option window     '60'
	option cooldown   '3600'
	option enabled    '0'

config alarm 'ssid_down'
	option name       'SSID Down'
	option level      '2'
	option threshold  '1'
	option window     '60'
	option cooldown   '300'
	option enabled    '1'

config alarm 'client_overload'
	option name       'Client Overload'
	option level      '1'
	option threshold  '100'
	option window     '300'
	option cooldown   '1800'
	option enabled    '0'